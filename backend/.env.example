# =============================================================================
# CoEDM Smart Manufacturing Control — Backend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# All variables map directly to backend/config.py Settings fields.
# =============================================================================

# ── PostgreSQL Database ──────────────────────────────────────────────────────
# Full SQLAlchemy connection URL.
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://coedm_user:yourpassword@localhost:5432/coedm_db

# SQLAlchemy connection pool tuning (safe defaults for most deployments)
DB_POOL_SIZE=5           # number of persistent connections kept in the pool
DB_MAX_OVERFLOW=10       # extra connections allowed above DB_POOL_SIZE
DB_POOL_TIMEOUT=30       # seconds to wait for a free connection
DB_POOL_RECYCLE=1800     # recycle connections older than 30 min (avoids stale TCP)
DB_ECHO=false            # set to "true" to log EVERY SQL statement (dev only!)

# ── ASRS — Automated Storage & Retrieval System (OPC-UA) ────────────────────
# PLC IP hosting the ASRS OPC-UA server
ASRS_OPCUA_URL=opc.tcp://10.10.14.104:4840
ASRS_OPCUA_NS=4          # OPC-UA namespace index for ASRS tags

# ── Hydraulic / Assembly Station (OPC-UA) ────────────────────────────────────
HYDRAULIC_OPCUA_URL=opc.tcp://10.10.14.113:4840

# ── MIRAC CNC Station (OPC-UA) ───────────────────────────────────────────────
MIRAC_OPCUA_URL=opc.tcp://10.10.14.102:4840

# ── VIBIT Vibration Sensor — Modbus TCP ──────────────────────────────────────
# The VIBIT device (or Modbus gateway) that exposes vibration/temperature data
VIBIT_HOST=10.10.14.103
VIBIT_PORT=502
VIBIT_UNIT_ID=1          # Modbus slave/unit ID

# ── FastAPI Application ───────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false              # set to "true" to enable FastAPI debug mode

# ── Logging ───────────────────────────────────────────────────────────────────
# One of: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO